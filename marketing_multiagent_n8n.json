    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.output || '{}';\nlet parsed;\ntry {\n  const clean = raw.replace(/```json|```/g, '').trim();\n  parsed = JSON.parse(clean);\n} catch(e) {\n  parsed = { approved: [], needs_review: [], rejected: [], error: e.message };\n}\nreturn [{ json: parsed }];"
      },
      "id": "node-parse",
      "name": "Function — Parse Agent Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1460, 340]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": false },
          "conditions": [
            {
              "leftValue": "={{ $json.needs_review.length }}",
              "rightValue": 0,
              "operator": { "type": "number", "operation": "gt" }
            }
          ]
        }
      },
      "id": "node-if-review",
      "name": "IF — Precisa revisão humana?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1700, 340]
    },
    {
      "parameters": {
        "select": "channel",
        "channelId": {
          "__rl": true,
          "value": "={{ $vars.SLACK_CHANNEL_ID }}",
          "mode": "id"
        },
        "text": "=*Conteúdo aguardando sua revisão*\n\n*Tema:* {{ $json.needs_review[0].topic }}\n*Score SEO:* {{ $json.needs_review[0].seo_score }}/10\n*Score Brand Voice:* {{ $json.needs_review[0].brand_score }}/10\n*Score Final:* {{ $json.needs_review[0].final_score }}/10\n\n*Preview do Blog:*\n{{ $json.needs_review[0].blog.substring(0, 300) }}...\n\nResponda com *APROVAR* ou *REJEITAR* + motivo.",
        "otherOptions": {}
      },
