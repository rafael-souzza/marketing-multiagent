    {
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "leftValue": "={{ $json.body.decision }}",
              "rightValue": "APROVAR",
              "operator": { "type": "string", "operation": "equals" }
            }
          ]
        }
      },
      "id": "node-if-approved",
      "name": "IF — Aprovado pelo humano?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [2160, 380]
    },
    {
      "parameters": {
        "jsCode": "const approved = $('node-parse').first().json.approved || [];\nconst humanApproved = $('node-if-approved').first().json;\nconst allApproved = [...approved];\nif (humanApproved && humanApproved.topic) allApproved.push(humanApproved);\nconst scheduled = allApproved.map(item => ({\n  ...item,\n  schedule: {\n    wordpress: '09:00',\n    instagram: '12:00',\n    linkedin: '08:00',\n    newsletter: '10:00'\n  },\n  scheduled_at: new Date().toISOString()\n}));\nreturn scheduled.map(s => ({ json: s }));"
      },
      "id": "node-scheduler",
      "name": "Function — Agendador inteligente",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2400, 340]
    },
