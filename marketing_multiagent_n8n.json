      "parameters": {
        "model": "claude-3-5-sonnet-20241022",
        "options": {
          "temperature": 0.2
        }
      },
      "id": "node-llm-seo",
      "name": "Claude 3.5 — Revisor SEO",
      "type": "@n8n/n8n-nodes-langchain.lmChatAnthropic",
      "typeVersion": 1.2,
      "position": [1040, 680]
